      "seed": 289034781,
      "version": 2,
      "versionNonce": 448805634,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777248422484,
      "link": null,
      "locked": false,
      "text": "src/controllers/auth.controller.ts:17-41 + src/shared/errors.ts:8-16\n!email → \"El campo email es obligatorio\"\n!email.includes(\"@\") → \"Formato de correo inválido\"\n!password → \"El campo contraseña es obligatorio\"\npassword.length < 6 → \"La contraseña debe tener al menos 6 caracteres\"\n!confirmPassword → \"El campo confirmar contraseña es obligatorio\"\npassword !== confirmPassword → \"Las contraseñas no coinciden\"\nSi errors no vacío → throw new ValidationError(\"Error de validación\", errors)",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "src/controllers/auth.controller.ts:17-41 + src/shared/errors.ts:8-16\n!email → \"El campo email es obligatorio\"\n!email.includes(\"@\") → \"Formato de correo inválido\"\n!password → \"El campo contraseña es obligatorio\"\npassword.length < 6 → \"La contraseña debe tener al menos 6 caracteres\"\n!confirmPassword → \"El campo confirmar contraseña es obligatorio\"\npassword !== confirmPassword → \"Las contraseñas no coinciden\"\nSi errors no vacío → throw new ValidationError(\"Error de validación\", errors)",
      "autoResize": true,
      "lineHeight": 1.25,
      "index": "av"
    },
